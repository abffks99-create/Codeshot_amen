# =====================================================
# CodeShot .gitignore
# 아래 파일/폴더는 깃허브에 올라가지 않아요
# =====================================================

# ⚠️ 1순위: 절대 올리면 안 되는 비밀 파일
.env

# RAG 벡터DB (용량이 크고 각자 생성되므로 제외)
rag_db/

# 사용자가 업로드한 이미지 (개인정보 보호)
static/uploads/

# Python 캐시 파일 (자동 생성되는 불필요한 파일)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# 가상환경 폴더 (각자 설치하므로 제외)
venv/
env/
.venv/

# IDE 설정 파일 (개인 설정이라 제외)
.vscode/
.idea/
*.swp
*.swo

# Mac 시스템 파일
.DS_Store

# Windows 시스템 파일
Thumbs.db
desktop.ini

# 로그 파일
*.log

# 임시 파일
*.tmp
*.temp
